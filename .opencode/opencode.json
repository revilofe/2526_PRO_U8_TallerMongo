{
  "$schema": "https://opencode.ai/config.json",

  "model": "opencode/minimax-m2.5-free",
  "default_agent": "taller-developer",

  "permission": {
    "bash": "ask",
    "read": "allow",
    "edit": "allow",
    "webfetch": "ask",
    "websearch": "ask",
    "skill": {
      "*": "allow"
    }
  },

  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/build/**",
      ".git/**",
      "**/.gradle/**",
      "**/.idea/**"
    ]
  },

  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  },

  "instructions": [
    "AGENTS.md",
    ".opencode/instructions/project.md"
  ],

  "agent": {
    "taller-developer": {
      "description": "Desarrolla la práctica CRUD de MongoDB con Kotlin y KMongo, manteniendo una implementación clara, didáctica y adecuada para alumnado de programación.",
      "mode": "primary",
//      "model": "GPT-5.4",
      "temperature": 0.2,
      "prompt": "{file:agents/taller-developer.md}",
      "permission": {
        "bash": "ask",
        "read": "allow",
        "edit": "allow",
        "webfetch": "ask",
        "websearch": "ask",
        "skill": {
          "*": "allow"
        }
      }
    },

    "taller-documenter": {
      "description": "Genera y mejora la documentación didáctica del taller MongoDB con Kotlin, incluyendo README, explicaciones, ejemplos y guías para el alumnado.",
      "mode": "subagent",
//      "model": "GPT-5.4",
      "temperature": 0.2,
      "prompt": "{file:agents/taller-documenter.md}",
      "permission": {
        "bash": "ask",
        "read": "allow",
        "edit": "allow",
        "webfetch": "ask",
        "websearch": "ask",
        "skill": {
          "*": "allow"
        }
      }
    },

    "git-committer": {
      "description": "Prepara commits limpios y profesionales siguiendo buenas prácticas de mensajes de commit, revisando previamente los cambios realizados.",
      "mode": "subagent",
//      "model": "GPT-5.4",
      "temperature": 0.1,
      "prompt": "{file:agents/git-committer.md}",
      "permission": {
        "bash": "ask",
        "read": "allow",
        "edit": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "skill": {
          "professional-commits": "allow",
          "*": "ask"
        }
      }
    }
  }
}
