classDiagram
    class MongoConfig {
        +String uri
        +String databaseName
        +MongoDriverProvider driverProvider
        +fromEnvironment(env)
    }

    class MongoConnection {
        -MongoConfig config
        -MongoClientFactory clientFactory
        +client() MongoClientAdapter
        +database() MongoDatabaseAdapter
        +close()
    }

    class DatabaseManager {
        +listDatabaseNames() List~String~
        +selectDatabase(databaseName) MongoDatabaseAdapter
        +materializeDatabase(databaseName, collectionName)
        +dropDatabase(databaseName)
    }

    class CollectionManager {
        +listCollectionNames() List~String~
        +createCollectionIfMissing(collectionName)
        +materializeCollection(collectionName, document)
        +renameCollection(currentName, newName)
        +dropCollection(collectionName)
    }

    class ProductService
    class ProductRepository {
        <<interface>>
    }
    class BibliotecaService
    class LibraryRepository {
        <<interface>>
    }
    class MongoDatabaseAdapter {
        +productRepository(collectionName) ProductRepository
        +libraryRepository() LibraryRepository
    }
    class Product
    class Autor
    class Libro
    class Prestamo
    class LibraryCounts

    MongoConnection --> MongoConfig : usa
    MongoConnection --> MongoDatabaseAdapter : crea
    MongoDatabaseAdapter --> ProductRepository : crea
    MongoDatabaseAdapter --> LibraryRepository : crea
    ProductService --> ProductRepository : depende de
    BibliotecaService --> LibraryRepository : depende de
    ProductRepository --> Product : persiste
    LibraryRepository --> Autor : persiste
    LibraryRepository --> Libro : persiste
    LibraryRepository --> Prestamo : persiste
    BibliotecaService --> LibraryCounts : construye
