sequenceDiagram
    actor Alumno
    participant Main
    participant ProductService
    participant ProductRepository
    participant Productos as "MongoCollection<Product>"
    participant BibliotecaService
    participant LibraryRepository
    participant Prestamos as "MongoCollection<Prestamo>"
    participant Libros as "MongoCollection<Libro>"

    Alumno->>Main: ejecutar ejemplo del taller

    rect rgb(245, 248, 255)
        Note over Main,Productos: Registrar un producto
        Main->>ProductService: register(product)
        ProductService->>ProductService: validar datos
        ProductService->>ProductRepository: insert(product)
        ProductRepository->>Productos: insertOne(product)
        Productos-->>ProductRepository: confirmacion
        ProductRepository-->>ProductService: product
        ProductService-->>Main: product
    end

    rect rgb(245, 255, 245)
        Note over Main,Libros: Devolver un prestamo
        Main->>BibliotecaService: returnLoan(prestamo)
        BibliotecaService->>BibliotecaService: validar identificador
        BibliotecaService->>LibraryRepository: markLoanAsReturned(prestamo._id)
        LibraryRepository->>Prestamos: updateOne(... devuelto = true)
        Prestamos-->>LibraryRepository: modifiedCount
        LibraryRepository-->>BibliotecaService: true/false
        BibliotecaService->>LibraryRepository: increaseCopiesByTitle(prestamo.libroTitulo, 1)
        LibraryRepository->>Libros: updateOne(... copias += 1)
        Libros-->>LibraryRepository: modifiedCount
        LibraryRepository-->>BibliotecaService: true/false
        BibliotecaService-->>Main: resultado final
    end
